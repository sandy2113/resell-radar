# Copy to .env and point at the same database as the Node API
DATABASE_URL=postgresql://user:pass@127.0.0.1:5433/resell%20radar
# If your host needs SSL (Neon, etc.):
# PGSSLMODE=require

# Scheduler loop interval in seconds (default 7200 = 2 hours)
PIPELINE_INTERVAL_SECONDS=7200
# 0 = do not rescore product_city_trend
UPDATE_PRODUCT_CITY_TREND=1
# 1 = copy live trend_keywords scores into existing `products` rows (names must match keywords)
SYNC_PRODUCT_TABLE=1
# Throttle pytrends (seconds between Google calls)
TRENDS_SLEEP_SECONDS=3
