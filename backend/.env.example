PORT=4000
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (optional — if unset, the API uses in-memory sample data)
# Local example:
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/resell_radar
# Supabase/Neon (often need SSL) — set DATABASE_SSL when the host requires it:
# DATABASE_URL=postgresql://user:pass@ep-....neon.tech/neondb?sslmode=require
# DATABASE_SSL=true
DATABASE_URL=
DATABASE_SSL=

# Python trend pipeline (separate service in /pipeline) uses the same DATABASE_URL.
# Run: psql ... -f db/migration_003_trend_pipeline.sql
